{
  "name": "webhatchery/interstellar-romance-backend",
  "description": "Interstellar Romance authoritative PHP backend",
  "type": "project",
  "require": {
    "php": "^8.1",
    "firebase/php-jwt": "^6.11",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S 0.0.0.0:8080 -t public",
    "test": "phpunit",
    "cs-check": "phpcs --standard=PSR12 src public scripts tests",
    "cs-fix": "phpcbf --standard=PSR12 src public scripts tests"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10"
  }
}
